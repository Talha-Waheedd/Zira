# Copy this file to .env and fill in at least ONE API key.

# --- Google Gemini (primary) ---
# FREE key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-ai-studio-key-here

# Optional — tries these in order if unset (deprecated 2.0/1.5 models are ignored):
# GEMINI_MODEL=gemini-2.5-flash

# --- Groq (optional fallback when Gemini fails or quota is exceeded) ---
# FREE key: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-key-here
# GROQ_MODEL=llama-3.3-70b-versatile
