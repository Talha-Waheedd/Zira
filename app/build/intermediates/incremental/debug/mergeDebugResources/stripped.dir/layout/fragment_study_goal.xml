<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvGoalTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/study_goal"
        android:textAppearance="@style/TextAppearance.Zira.HeadlineLarge"
        android:textColor="@color/on_background"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvGoalSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/study_goal_subtitle"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
        android:textColor="@color/on_surface_variant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGoalTitle" />

    <TextView
        android:id="@+id/tvMinutesValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:textAppearance="@style/TextAppearance.Zira.TitleLarge"
        android:textColor="@color/primary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvGoalSubtitle" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderDailyGoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:stepSize="5"
        android:valueFrom="15"
        android:valueTo="120"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvMinutesValue"
        app:tickVisible="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15 min"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="@color/on_surface_variant"
        app:layout_constraintStart_toStartOf="@id/sliderDailyGoal"
        app:layout_constraintTop_toBottomOf="@id/sliderDailyGoal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="120 min"
        android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
        android:textColor="@color/on_surface_variant"
        app:layout_constraintEnd_toEndOf="@id/sliderDailyGoal"
        app:layout_constraintTop_toBottomOf="@id/sliderDailyGoal" />

</androidx.constraintlayout.widget.ConstraintLayout>
