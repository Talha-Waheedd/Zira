<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".ZiraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Zira"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Zira.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.onboarding.OnboardingActivity"
            android:exported="false" />

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.ask.AskActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.flashcards.FlashcardActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.flashcards.FlashcardReviewActivity"
            android:exported="false"
            android:parentActivityName=".ui.flashcards.FlashcardActivity" />

        <activity
            android:name=".ui.progress.ProgressActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.profile.ProfileActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".ui.quiz.QuizActivity"
            android:exported="false"
            android:parentActivityName=".ui.home.HomeActivity" />

        <activity
            android:name=".ui.quiz.ResultActivity"
            android:exported="false"
            android:parentActivityName=".ui.quiz.QuizActivity" />

        <activity
            android:name=".ui.schedule.ScheduleActivity"
            android:exported="false"
            android:parentActivityName=".ui.profile.ProfileActivity" />

    </application>

</manifest>
