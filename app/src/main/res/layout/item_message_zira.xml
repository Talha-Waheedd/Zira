<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="top"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="4dp"
    android:paddingEnd="56dp"
    android:paddingBottom="4dp">

    <ImageView
        android:id="@+id/ivAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/avatar_circle"
        android:contentDescription="@string/zira_avatar_desc"
        android:padding="6dp"
        android:src="@drawable/ic_zira" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_bubble_zira"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:textAppearance="@style/TextAppearance.Zira.BodyLarge"
            android:textColor="@color/on_surface" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFollowUps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            app:chipSpacingHorizontal="6dp"
            app:singleLine="false"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

    </LinearLayout>

</LinearLayout>
